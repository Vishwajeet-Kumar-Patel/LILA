# Local development — these are the defaults in nakamaClient.ts, no need to set them locally.
# Copy this file to .env.local and fill in values for production.

# VITE_NAKAMA_HOST=127.0.0.1
# VITE_NAKAMA_PORT=7350
# VITE_NAKAMA_USE_SSL=false

# --- For Production (e.g. Railway or Render deployment) ---
# VITE_NAKAMA_HOST=your-nakama-server.up.railway.app
# VITE_NAKAMA_PORT=443
# VITE_NAKAMA_USE_SSL=true
